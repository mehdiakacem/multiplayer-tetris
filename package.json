{
  "name": "red-tetris",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "build:client": "vite build",
    "lint:client": "eslint ./src/client",
    "preview:client": "vite preview",
    "dev:server": "nodemon --watch src/server --ext js --exec 'node src/server/index.js'",
    "start:server": "node src/server/index.js",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:client\" \"npm run dev:server\""
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.10.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitejs/plugin-react": "^5.1.1",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "vite": "^7.2.4"
  }
}
